<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:PatientCareChatbotPortal.Views"
             x:Class="PatientCareChatbotPortal.Pages.InfoPage"
             Title="Informational Screen">
    <Grid RowDefinitions="Auto,*">
        <views:NavBanner Grid.Row="0" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="16">
                <Label Text="Informational Screen" Style="{StaticResource PageHeading}" />
                <Label Text="Read-only metadata from the current application configuration." Style="{StaticResource PageSubtitle}" />

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Current Build" Style="{StaticResource SectionHeading}" FontSize="18" />
                        <Editor x:Name="BuildSummaryEditor" IsReadOnly="True" HeightRequest="100" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Author and Copyright" Style="{StaticResource SectionHeading}" FontSize="18" />
                        <Editor x:Name="AuthorEditor" IsReadOnly="True" HeightRequest="80" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Application Description" Style="{StaticResource SectionHeading}" FontSize="18" />
                        <Editor x:Name="DescriptionEditor" IsReadOnly="True" HeightRequest="120" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
