<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:PatientCareChatbotPortal.Views"
             x:Class="PatientCareChatbotPortal.Pages.StartSessionPage"
             Title="Start Session">
    <Grid RowDefinitions="Auto,*" Padding="0">
        <views:NavBanner Grid.Row="0" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="16">
                <Label Text="Patient Care Chatbot Portal" Style="{StaticResource PageHeading}" />
                <Label Text="Start a session and navigate to Admin, User, or Info screens from the banner."
                       Style="{StaticResource PageSubtitle}" />

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Session Controls" Style="{StaticResource SectionHeading}" />
                        <Button Text="▶ Start Session" Clicked="OnStartSessionClicked" />
                        <Label x:Name="SessionStatusLabel" Text="Session not started yet." />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
